<form style="background-color: #EBEBD3; box-shadow: 0px 10px 0px 0px rgba(0, 0, 0, 1);" class="p-10 w-11/12 md:w-2/6 mx-auto mt-20 rounded-[50px] shadow-lg flex flex-col items-center space-y-6">
    
    <!-- Pestañas de navegación -->
    <div class="flex space-x-4 items-center justify-between w-3/4">
        <button type="button" class="text-lg p-2 font-semibold hover:bg-amaclaro transition duration-300 ease-in-out hover:scale-105 hover:rounded-[15px]">
            Iniciar sesión
        </button>
        <button type="button" class="text-lg p-2 font-semibold hover:bg-amaclaro transition duration-300 ease-in-out hover:scale-105 hover:rounded-[15px]">
            Crear cuenta
        </button>
    </div>

    <!-- Campo: Usuario -->
    <div class="flex space-x-4 items-center justify-center w-full">
        <div class="flex items-center justify-center w-12 h-12 transparent rounded-full">
            <img class="h-10" src="../Img/Yu.png" alt="Icono de usuario">
        </div>
        <input class="bg-amascuro p-3 rounded-[5px] w-3/4 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-400" type="text" id="user" name="user" placeholder="Usuario" required>
    </div>

    <!-- Campo: Correo -->
    <div class="flex space-x-4 items-center justify-center w-full">
        <div class="flex items-center justify-center w-12 h-12 transparent rounded-full">
            <img class="h-10" src="../Img/Reo.png" alt="Icono de correo">
        </div>
        <input class="bg-amascuro p-3 rounded-[5px] w-3/4 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-400" type="email" id="email" name="email" placeholder="Correo electrónico" required>
    </div>

    <!-- Campo: Contraseña -->
    <div class="flex space-x-4 items-center justify-center w-full h-12">
        <div class="flex items-center justify-center w-12 h-12 transparent rounded-full">
            <img class="h-10" src="../Img/Pass.png" alt="Icono de contraseña">
        </div class="flex items-center justify-center w-12 h-12 transparent rounded-full">
        <input class="bg-amascuro p-3 rounded-[5px] w-3/4 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-400" type="password" id="pass" name="pass" placeholder="Contraseña" required>
    </div>

    <!-- Campo: Fecha/Hora -->
    <div class="flex space-x-4 items-center justify-center w-full">
        <div class="flex items-center justify-center w-12 h-12 transparent rounded-full">
            <img class="h-10" src="../Img/Sage.png" alt="Icono de fecha">
        </div>
        <input class="bg-amascuro p-3 rounded-[5px] w-3/4 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-400" type="datetime-local" id="fecha" name="fecha" required>
    </div>

    <hr style="border: 1px solid black; width: 100%; margin: 4px;">
    
    <!-- Botón de Envío -->
    <button type="submit" style="box-shadow: 0px 10px 0px 0px rgba(0, 0, 0, 1);" class="bg-amaluzo hover:bg-blue-600 transition-colors font-bold p-3 rounded w-3/4">
        Crear cuenta
    </button>
</form>